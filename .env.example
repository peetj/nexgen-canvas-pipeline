# TODAY_INTRO_AGENT_URL=https://nexgen-canvas-agent.<your-subdomain>.workers.dev/today-intro
# TASK_A_AGENT_URL=https://nexgen-canvas-agent.<your-subdomain>.workers.dev/task-a-content
# QUIZ_AGENT_API_KEY=optional
# TODAY_INTRO_AGENT_API_KEY=optional
# TASK_A_AGENT_API_KEY=optional

