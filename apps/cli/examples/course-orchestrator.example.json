{
  "schemaVersion": "course-orchestrator.v2",
  "moduleTemplate": {
    "name": "Session {nn} - {topic}",
    "steps": [
      { "type": "session-headers" },
      {
        "type": "today-section",
        "pageTitle": "Introduction: {topic}",
        "notes": "Students focus on {topic}, review the session success criteria, and prepare evidence they need to capture during Session {nn}.",
        "imageUrl": "https://example.com/session-{nn}.jpg"
      },
      {
        "type": "subheader",
        "title": "Feedback"
      },
      {
        "type": "page",
        "title": "Session {nn} Feedback",
        "afterHeaderTitle": "Feedback",
        "content": [
          {
            "type": "markdown",
            "value": "## Feedback\nStudents reflect on {topic} and document one improvement they will make before the next session."
          }
        ]
      }
    ]
  },
  "sessions": [
    {
      "sessionNumber": 1,
      "topic": "Example Build"
    },
    {
      "sessionNumber": 2,
      "topic": "Prototype Review"
    }
  ]
}
